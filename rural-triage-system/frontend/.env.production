# Shuruksha Link - Production environment
# Vite reads .env.production automatically when running `npm run build`.
# Set VITE_API_BASE_URL to the deployed Render backend origin
# (no trailing slash, e.g. https://shuruksha-link-api.onrender.com).
VITE_API_BASE_URL=https://shuruksha-link-api.onrender.com
VITE_APP_ENV=production
