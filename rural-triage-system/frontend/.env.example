# Frontend env example - copy to .env.development or .env.production
# (DO NOT commit real .env files; the root .gitignore already ignores them.)

# Absolute base URL of the deployed backend.
# - Dev  : leave empty to use the Vite dev-server proxy (see vite.config.js)
# - Prod : https://shuruksha-link-api.onrender.com  (no trailing slash)
VITE_API_BASE_URL=

# Free-form label, surfaced in the UI / build logs for quick identification.
VITE_APP_ENV=development
