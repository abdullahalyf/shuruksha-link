# Backend env example - copy to .env locally; do NOT commit real .env files
# (the root .gitignore already excludes them).

# Google Gemini API key (https://aistudio.google.com/apikey).
# Get one with free-tier access (15 req/min) and paste it here. Required.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides:
# PORT defaults to 5000; Render sets PORT for us automatically.
# PORT=5000
# NODE_ENV=development   # 'production' in deployed env
